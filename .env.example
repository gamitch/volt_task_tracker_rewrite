# Copy this file to .env (gitignored) and fill in real values locally.
# Never commit real values — .env is gitignored; only this .env.example (with blank
# placeholders) is committed.

# Supabase project URL and anon (public) key, exposed to the Vite client bundle.
# Find these in the Supabase project dashboard under Project Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
