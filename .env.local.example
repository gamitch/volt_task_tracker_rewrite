# Copy to .env.local and fill in. .env.local is gitignored — never commit real values.

# --- Frontend (Vite, safe to expose to the browser) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-side secrets: DO NOT put these here ---
# CHECKIN_HMAC_SECRET and RESEND_API_KEY live in Supabase Edge Function secrets
# (set via `supabase secrets set ...`), not in this file.

# --- Migration only (scripts/migrate.ts) ---
# Needed solely to migrate data from the old Lovable Cloud project.
# Set these in your shell when running the migration; leave blank otherwise.
OLD_SUPABASE_URL=
OLD_SERVICE_ROLE_KEY=
